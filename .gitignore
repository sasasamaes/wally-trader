# macOS
.DS_Store
._*

# Temp data / backtest artifacts
/tmp/
*.json
!package.json
!package-lock.json
!.claude/settings.json
!.claude/**/*.json
# OpenCode soporte total — config primary (root) + MCP source-of-truth + legacy back-compat
!opencode.json
!system/mcp/servers.json
!.opencode/config.json
# Hermes adapter — generated skills tree (tracked so clone-and-go works)
!.hermes/skills/**/*.json

# Screenshots (can be large)
tradingview-mcp/screenshots/
**/screenshots/

# Logs
*.log
*.pid
*.out

# Session-specific ephemeral alert scripts
.claude/scripts/alert_*.sh

# IDE
.vscode/
.idea/
*.swp
*.swo

# Environment secrets
.env
.env.local
.env.*.local
*credentials*
*.key
*.pem

# MT5 credentials
.claude/.env

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/

# Node
node_modules/

# OS
Thumbs.db

# Claude project workdir (if any)
.claude/projects/

# Claude settings locales (overrides personales)
.claude/settings.local.json

# Nested git repos (tracked separately upstream)
claude-tradingview-mcp-trading/
tradingview-mcp/

# Discipline & Observability runtime cache (macro events + bitunix log errors)
.claude/cache/

# ML System — cache de data histórica Binance y modelos entrenados
scripts/ml_system/data/
scripts/ml_system/supervised/model/*.pkl
scripts/ml_system/supervised/model/*.json
scripts/ml_system/**/*.parquet

# Git worktrees (isolated dev branches)
.worktrees/

# Personal trading log — gitignored para open source (contiene capital real + trades específicos)
.claude/profiles/retail/memory/trading_log.md
.claude/memory/trading_log.md
.claude/scripts/.venv/
