# Environment variables — COPY to .env and fill
# .env is gitignored; never commit real values

# ─── MT5 / FTMO credentials ───────────────────────────────
FTMO_LOGIN=
FTMO_PASSWORD=
FTMO_READONLY_PASSWORD=
FTMO_SERVER=FTMO-Demo
MT5_FILES_PATH=

# MT5_FILES_PATH: auto-detected by install.sh. Override here if needed.
# Example on macOS:
# MT5_FILES_PATH=/Users/<you>/Library/Application Support/MetaTrader 5/Bottles/metatrader5/drive_c/users/<you>/AppData/Roaming/MetaQuotes/Terminal/<hash>/MQL5/Files

# ─── Notion MCP integration (opcional) ────────────────────
# Si los llenás, journal-keeper + commands trading escriben ADEMÁS del .md local a Notion
# Si quedan vacíos, solo se usa el .md local (comportamiento original)
# Setup: seguir docs/NOTION_SETUP.md para crear las DBs + conectar MCP
#
# Copiá el DB ID desde la URL de Notion: notion.so/<workspace>/<DATABASE_ID>?v=...
# (es el string hex de 32 chars después del workspace y antes del ?)

NOTION_RETAIL_DB_ID=
NOTION_FTMO_DB_ID=
