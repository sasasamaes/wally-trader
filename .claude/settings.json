{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "statusLine": {
    "type": "command",
    "command": "~/wally-trader/.claude/scripts/statusline.sh",
    "refreshInterval": 30
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/wally-trader/.claude/scripts/session_start.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/wally-trader/.claude/scripts/stop_hook.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/wally-trader/.claude/scripts/preprompt_check.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch",
      "Bash(git:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git pull:*)",
      "Bash(git status)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(python3:*)",
      "Bash(chmod:*)",
      "Bash(mkdir:*)",
      "Bash(ls:*)",
      "Bash(~/wally-trader/.claude/scripts/*)",
      "Bash(jq:*)",
      "Bash(cat /tmp/*)",
      "Bash(cat ~/.claude/*)",
      "Bash(date:*)",
      "Bash(sleep:*)",
      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "mcp__tradingview__tv_health_check",
      "mcp__tradingview__tv_launch",
      "mcp__tradingview__quote_get",
      "mcp__tradingview__chart_get_state",
      "mcp__tradingview__chart_set_symbol",
      "mcp__tradingview__chart_set_timeframe",
      "mcp__tradingview__chart_set_type",
      "mcp__tradingview__chart_manage_indicator",
      "mcp__tradingview__chart_scroll_to_date",
      "mcp__tradingview__data_get_ohlcv",
      "mcp__tradingview__data_get_study_values",
      "mcp__tradingview__data_get_pine_lines",
      "mcp__tradingview__data_get_pine_labels",
      "mcp__tradingview__data_get_pine_boxes",
      "mcp__tradingview__data_get_pine_tables",
      "mcp__tradingview__data_get_equity",
      "mcp__tradingview__data_get_strategy_results",
      "mcp__tradingview__data_get_trades",
      "mcp__tradingview__symbol_search",
      "mcp__tradingview__symbol_info",
      "mcp__tradingview__draw_shape",
      "mcp__tradingview__draw_list",
      "mcp__tradingview__draw_clear",
      "mcp__tradingview__draw_remove_one",
      "mcp__tradingview__draw_get_properties",
      "mcp__tradingview__pine_new",
      "mcp__tradingview__pine_open",
      "mcp__tradingview__pine_set_source",
      "mcp__tradingview__pine_get_source",
      "mcp__tradingview__pine_save",
      "mcp__tradingview__pine_compile",
      "mcp__tradingview__pine_smart_compile",
      "mcp__tradingview__pine_check",
      "mcp__tradingview__pine_get_errors",
      "mcp__tradingview__pine_get_console",
      "mcp__tradingview__pine_list_scripts",
      "mcp__tradingview__pine_analyze",
      "mcp__tradingview__ui_mouse_click",
      "mcp__tradingview__ui_click",
      "mcp__tradingview__ui_hover",
      "mcp__tradingview__ui_find_element",
      "mcp__tradingview__ui_evaluate",
      "mcp__tradingview__ui_open_panel",
      "mcp__tradingview__ui_keyboard",
      "mcp__tradingview__ui_scroll",
      "mcp__tradingview__ui_type_text",
      "mcp__tradingview__ui_fullscreen",
      "mcp__tradingview__tv_ui_state",
      "mcp__tradingview__tv_discover",
      "mcp__tradingview__pane_list",
      "mcp__tradingview__pane_focus",
      "mcp__tradingview__pane_set_symbol",
      "mcp__tradingview__pane_set_layout",
      "mcp__tradingview__tab_list",
      "mcp__tradingview__tab_new",
      "mcp__tradingview__tab_switch",
      "mcp__tradingview__tab_close",
      "mcp__tradingview__layout_list",
      "mcp__tradingview__layout_switch",
      "mcp__tradingview__capture_screenshot",
      "mcp__tradingview__watchlist_add",
      "mcp__tradingview__watchlist_get",
      "mcp__tradingview__depth_get",
      "mcp__tradingview__batch_run",
      "mcp__tradingview__replay_start",
      "mcp__tradingview__replay_step",
      "mcp__tradingview__replay_autoplay",
      "mcp__tradingview__replay_trade",
      "mcp__tradingview__replay_status",
      "mcp__tradingview__replay_stop",
      "mcp__tradingview__alert_create",
      "mcp__tradingview__alert_list",
      "mcp__tradingview__alert_delete",
      "mcp__tradingview__indicator_set_inputs",
      "mcp__tradingview__indicator_toggle_visibility"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)"
    ]
  }
}
