# =============================================================================
# Wally Trader — Environment Variables (template)
# =============================================================================
# Copy this file to `.env` at the repo root and fill in real values for local
# development. Never commit `.env`. In production each value is set as a Fly.io
# secret (api + workers) or a Vercel env var (web).
#
# Generate a fresh MASTER_KEK once with:
#   python -c "import secrets,base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
# =============================================================================


# ----------------------------------- App -------------------------------------
APP_NAME=wally-api
ENV=dev                     # dev | staging | production
DEBUG=true
LOG_LEVEL=DEBUG             # DEBUG | INFO | WARNING | ERROR
API_V1_PREFIX=/api/v1

# Comma-separated list of allowed origins for CORS
CORS_ALLOWED_ORIGINS=["http://localhost:3000"]


# --------------------------------- Database ----------------------------------
# When using docker-compose: postgresql+asyncpg://wally:wally@postgres:5432/wally_dev
# When running locally:      postgresql+asyncpg://wally:wally@localhost:5432/wally_dev
DATABASE_URL=postgresql+asyncpg://wally:wally@localhost:5432/wally_dev
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20


# ----------------------------------- Redis -----------------------------------
REDIS_URL=redis://localhost:6379/0


# ----------------------------- Auth (Clerk) ----------------------------------
# Sign up at https://clerk.com (free up to 10k MAU). Create an application and
# copy the values from the API Keys page.
CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me
CLERK_JWT_ISSUER=https://your-app.clerk.accounts.dev
CLERK_WEBHOOK_SECRET=whsec_replace_me


# --------------------------- Encryption (CRITICAL) ---------------------------
# 32-byte base64-encoded master Key Encryption Key.
# LOSE THIS = LOSE EVERY USER'S API KEY. Keep it in two places:
#   1. Fly.io secrets / Vercel env vars in prod
#   2. A sealed backup in 1Password (admin vault only)
MASTER_KEK=replace_with_output_of_generate_master_kek


# ------------------------------ Billing (Stripe) -----------------------------
# Use test mode keys (sk_test_…) for beta. Switch to live mode only when
# friends start paying real money.
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRICE_ID_BASE=price_replace_me_base_monthly
STRIPE_METER_AGENT_CALLS_ID=mtr_replace_me_agent_calls


# --------------------------- Beta access whitelist ---------------------------
# Only these emails can register during closed beta. Comma-separated.
BETA_ALLOWED_EMAILS=["josecampos@example.com"]


# -------------------------------- Observability ------------------------------
# Optional: leave blank to disable Sentry.
SENTRY_DSN=


# ----------------------------- Watcher channels ------------------------------
# Used by .claude/scripts/notify_hub.py + price_feeds.py. All optional —
# leaving blank disables that channel and falls back gracefully (macOS notif
# + dashboard always work). See .claude/scripts/NOTIFY_SETUP.md for setup.

# Telegram bot — push WARN/CRITICAL events to a chat.
# Create bot via @BotFather, get chat_id from @getidsbot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Resend — transactional email for CRITICAL events (free tier 100/day).
RESEND_API_KEY=
RESEND_FROM_EMAIL=alerts@yourdomain.com
RESEND_TO_EMAIL=

# TwelveData — forex / index price feed for fotmarkets / ftmo profiles.
# Free tier: 800 req/day, 8 req/min. Sign up at twelvedata.com.
TWELVEDATA_API_KEY=

# Live Binance Futures execution — only set if you enable --real on /order
# for the retail profile. Watcher v1 leaves this stubbed.
BINANCE_API_KEY=
BINANCE_API_SECRET=


# =============================================================================
# Frontend-only (read by web/, not api/)
# =============================================================================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
