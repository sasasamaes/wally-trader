# Jesse — variables de entorno (copia a .env y ajusta)
# Alineado con el stack oficial https://github.com/jesse-ai/jesse-stack-docker
# Fuente autoritativa: https://docs.jesse.trade/docs/getting-started/docker

# ── Dashboard / API / MCP ──
# Puerto del dashboard de Jesse (default oficial 8888). El MCP se sirve desde el mismo
# proceso de Jesse; la URL exacta del MCP (termina en /mcp) la imprime `jesse run` o la
# expone el dashboard — CONFÍRMALA ahí, no la asumas. El registro en Claude Code usó
# http://localhost:9002/mcp como default documentado; ajústalo si Jesse imprime otro puerto.
JESSE_PORT=8888

# ── PostgreSQL (servicio "db", postgres:14-alpine) ──
POSTGRES_PORT=5432
POSTGRES_NAME=jesse_db
POSTGRES_USERNAME=jesse_user
POSTGRES_PASSWORD=password
