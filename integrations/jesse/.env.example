# Jesse — variables de entorno (copia a .env y ajusta)
# Fuente autoritativa: https://docs.jesse.trade/docs/getting-started

# ── Dashboard / API ──
# Puerto del dashboard de Jesse (en el video el presentador lo cambió a 9000).
JESSE_PORT=9000

# Puerto del servidor MCP (Jesse imprime la URL final terminada en /mcp al correr `jesse run`).
# Suele ser 9002 por default si no se cambia. Confirma con la salida de `jesse run`.
MCP_PORT=9002

# Password del dashboard (Jesse pide login local).
JESSE_PASSWORD=changeme

# ── PostgreSQL ──
POSTGRES_HOST=jesse-postgres
POSTGRES_PORT=5432
POSTGRES_NAME=jesse_db
POSTGRES_USERNAME=jesse_user
POSTGRES_PASSWORD=changeme

# ── Redis ──
REDIS_HOST=jesse-redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
